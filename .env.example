# FHDC RecallDesk environment variables
NEXT_PUBLIC_APP_NAME="FHDC RecallDesk"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Use the relational Supabase table backend for live/Render deployments.
STORAGE_DRIVER="supabase_tables"
SUPABASE_URL="https://your-fhdc-recalldesk-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-server-side-service-role-or-secret-key"

APP_SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
ADMIN_SETUP_KEY="fhdc-admin-setup-2026"
